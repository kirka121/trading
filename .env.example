# Questrade API credentials
# Get from: Questrade → My Profile → API Centre → Register a personal app
# Refresh tokens are SINGLE-USE — the bot rotates this on every run.
QUESTRADE_REFRESH_TOKEN=

# "true" = practice (paper) environment, "false" = live brokerage
QUESTRADE_PRACTICE=true

# Optional — pin to a specific account number. If blank, the bot picks the first one.
QUESTRADE_ACCOUNT_ID=

# Portfolio value — used to calculate position size
PORTFOLIO_VALUE_USD=10000

# Trade limits — your guardrails
MAX_TRADE_SIZE_USD=500        # No single trade exceeds this notional
MAX_TRADES_PER_DAY=3          # Bot stops after this many trades per day

# Timeframe (symbols come from the watchlist in rules.json — bot iterates all of them per run)
TIMEFRAME=5m

# Optional — override which strategy runs. Defaults to "active_strategy" in rules.json.
# Useful for switching between strategies without editing the file.
# ACTIVE_STRATEGY=vwap_rsi_ema

# "true" = log decisions but never send orders. "false" = actually send orders
# (still goes to PRACTICE env unless QUESTRADE_PRACTICE=false too)
PAPER_TRADING=true
