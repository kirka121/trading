# Questrade API credentials — used ONLY to fetch market data (candles).
# The bot is decision-only and never places orders, so a practice-environment
# refresh token is sufficient (and recommended).
# Get from: Questrade → My Profile → API Centre → Register a personal app
# Refresh tokens are SINGLE-USE — the bot rotates this on every run.
QUESTRADE_REFRESH_TOKEN=

# Optional — pin to a specific account number. If blank, the bot picks the first one.
QUESTRADE_ACCOUNT_ID=

# Portfolio value — used to compute the suggested position size shown in
# the decision table. Informational only; no orders are placed.
PORTFOLIO_VALUE_USD=10000

# Suggested-size guardrails — informational only.
MAX_TRADE_SIZE_USD=500        # No single suggested trade exceeds this notional
MAX_TRADES_PER_DAY=3          # Bot stops emitting BUY/SELL decisions after this many per day
